# ─── Auth ────────────────────────────────────────────────────────────────────
# Password for the single-user login
AUTH_PASSWORD=changeme

# Secret key for JWT signing (generate a long random string)
JWT_SECRET=your-secret-key-here

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Required for Gmail, Google Calendar, and Google Drive integrations.
# Chatty does NOT ship with bundled Google credentials — you must create your
# own OAuth client. See docs/gmail-setup.md or DEPLOY.md for full instructions.
#
# Quick version:
# 1. Create a project at console.cloud.google.com
# 2. Enable: Gmail API, Google Calendar API, Google Drive API (as needed)
# 3. OAuth consent screen → External → fill in app details
# 4. Credentials → Create OAuth client ID → Web application
# 5. Authorized redirect URI: {your-chatty-url}/api/oauth/callback
#    (e.g. http://localhost:8000/api/oauth/callback for local dev)
# 6. Set OAUTH_REDIRECT_URI below to the same value you registered
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OpenAI OAuth ────────────────────────────────────────────────────────────
# OAuth app credentials from platform.openai.com
OPENAI_CLIENT_ID=
OPENAI_CLIENT_SECRET=

# ─── QuickBooks OAuth ────────────────────────────────────────────────────────
# Create an app at developer.intuit.com
# Redirect URI in Intuit portal: https://auth.mechatty.com/callback
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
# Defaults to sandbox. For production: https://quickbooks.api.intuit.com/v3/company
# QUICKBOOKS_API_BASE_URL=https://sandbox-quickbooks.api.intuit.com/v3/company

# ─── Webby (Phase 2) ─────────────────────────────────────────────────────────
# GitHub Personal Access Token with repo scope
WEBBY_GITHUB_TOKEN=
# e.g. myusername/my-website
WEBBY_GITHUB_REPO=

# ─── Encryption ─────────────────────────────────────────────────────────────
# For deployed instances: Fernet encryption key for credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank for local use (key stored in OS keychain automatically).
ENCRYPTION_KEY=

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# URL of the Baileys sidecar (whatsapp-bridge). Leave blank to disable.
WHATSAPP_BRIDGE_URL=
# Shared secret for sidecar ↔ backend auth (X-Api-Key header).
# Also used to verify inbound webhook calls from the sidecar.
# Set the same value as API_KEY on the sidecar side.
WHATSAPP_BRIDGE_API_KEY=
# Optional: override webhook verification secret (defaults to WHATSAPP_BRIDGE_API_KEY)
WHATSAPP_WEBHOOK_SECRET=

# ─── OAuth Redirect URI ──────────────────────────────────────────────────────
# Required for Google integrations (and any other OAuth provider that needs a
# redirect URI registered ahead of time). Set this to your Chatty instance's
# callback URL — it MUST match exactly what you registered with the provider.
#
# Local dev:    http://localhost:8000/api/oauth/callback
# Railway:      https://your-chatty-url.up.railway.app/api/oauth/callback
# Custom host:  https://your-domain.com/api/oauth/callback
# OAUTH_REDIRECT_URI=

# ─── Server ──────────────────────────────────────────────────────────────────
# CORS origins (comma-separated). Defaults to localhost dev servers.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Feature flags
MULTI_USER_ENABLED=false
