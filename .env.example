# ─── Auth ────────────────────────────────────────────────────────────────────
# Password for the single-user login
AUTH_PASSWORD=changeme

# Secret key for JWT signing (generate a long random string)
JWT_SECRET=your-secret-key-here

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create an OAuth 2.0 Client ID at console.cloud.google.com
# Application type: Desktop app (for local PKCE flow)
# Enable: Generative Language API, Gmail API, Google Calendar API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OpenAI OAuth ────────────────────────────────────────────────────────────
# OAuth app credentials from platform.openai.com
OPENAI_CLIENT_ID=
OPENAI_CLIENT_SECRET=

# ─── Webby (Phase 2) ─────────────────────────────────────────────────────────
# GitHub Personal Access Token with repo scope
WEBBY_GITHUB_TOKEN=
# e.g. myusername/my-website
WEBBY_GITHUB_REPO=

# ─── Server ──────────────────────────────────────────────────────────────────
# CORS origins (comma-separated). Defaults to localhost dev servers.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Feature flags
MULTI_USER_ENABLED=false
